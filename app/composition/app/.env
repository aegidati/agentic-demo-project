# PostgreSQL Configuration
POSTGRES_DB=composition_db
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme_db_password
POSTGRES_PORT=5432

# Backend Configuration
BACKEND_PORT=3000
IAM_AUDIT_RETENTION_DAYS=365
IAM_AUDIT_SINK=file
IAM_AUDIT_FILE_PATH=/var/lib/app/audit/events.ndjson

# Web Frontend Configuration
WEB_PORT=8080

# API Configuration (used in web container at build time)
VITE_API_BASE_URL=http://backend:3000

# Restart policies (dev: no/on-failure, prod: unless-stopped)
POSTGRES_RESTART_POLICY=unless-stopped
BACKEND_RESTART_POLICY=unless-stopped
WEB_RESTART_POLICY=unless-stopped

# Resource limits (override per environment as needed)
POSTGRES_MEM_LIMIT=512m
POSTGRES_CPUS=1.0
POSTGRES_PIDS_LIMIT=256

BACKEND_MEM_LIMIT=512m
BACKEND_CPUS=1.0
BACKEND_PIDS_LIMIT=256

WEB_MEM_LIMIT=256m
WEB_CPUS=0.50
WEB_PIDS_LIMIT=128
