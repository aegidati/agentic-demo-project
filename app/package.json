{
  "name": "clean-backend-app",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal clean architecture backend starter",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
